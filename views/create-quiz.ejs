        // Validate current question
        function validateCurrentQuestion() {
            const questionText = getQuestionText().trim();
            const answerFormat = document.querySelector('input[name="answerFormat"]:checked').value;

            if (!questionText) {
                alert('Please enter a question text');
                return false;
            }

            if (answerFormat === 'multiple') {
                const options = document.querySelectorAll('.option-input');
                const filledOptions = Array.from(options).filter(opt => opt.value.trim());

                if (filledOptions.length < 2) {
                    alert('Please provide at least 2 options');
                    return false;
                }

                const correctAnswers = document.querySelectorAll('.correct-answer-radio:checked');
                if (correctAnswers.length === 0) {
                    alert('Please select at least one correct answer');
                    return false;
                }
            } else {
                const expectedAnswer = document.getElementById('expectedAnswer').value.trim();
                if (!expectedAnswer) {
                    alert('Please provide the expected answer');
                    return false;
                }
            }

            return true;
        }

        // Collect question data
        function collectQuestionData() {
            const questionText = getQuestionText();
            const answerFormat = document.querySelector('input[name="answerFormat"]:checked').value;

            const question = {
                questionText: questionText,
                question: questionText, // Add both for compatibility
                answerFormat: answerFormat,
                image: currentQuestionImage,
                points: 1 // Default points value
            };

            if (answerFormat === 'multiple') {
                const selectionType = document.querySelector('input[name="selectionType"]:checked').value;
                const options = [];
                const correctAnswers = [];

                document.querySelectorAll('.option-input').forEach((input, index) => {
                    if (input.value.trim()) {
                        options.push(input.value.trim());
                        const isCorrect = document.querySelectorAll('.correct-answer-radio')[index].checked;
                        if (isCorrect) {
                            correctAnswers.push(index);
                        }
                    }
                });

                question.selectionType = selectionType;
                question.options = options;
                question.correctAnswers = correctAnswers;
            } else {
                question.expectedAnswer = document.getElementById('expectedAnswer').value.trim();
            }

            return question;
        }

