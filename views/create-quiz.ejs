        // ── Rich Text Editor helper ──────────────────────────────────────
        function rteCmd(id, cmd) {
            document.getElementById(id).focus();
            document.execCommand(cmd, false, null);
        }

        // Strip everything except <b>, <i>, <u>, <strong>, <em> — fires on paste
        function rtePasteSanitize(e) {
            e.preventDefault();
            const html = (e.clipboardData || window.clipboardData).getData('text/html');
            const plain = (e.clipboardData || window.clipboardData).getData('text/plain');

            let clean = '';
            if (html) {
                // Keep only safe inline tags, strip everything else
                clean = html
                    .replace(/<span[^>]*font-weight:\s*700[^>]*>([\s\S]*?)<\/span>/gi, '<b>$1</b>')
                    .replace(/<span[^>]*font-style:\s*italic[^>]*>([\s\S]*?)<\/span>/gi, '<i>$1</i>')
                    .replace(/<span[^>]*text-decoration:\s*underline[^>]*>([\s\S]*?)<\/span>/gi, '<u>$1</u>')
                    .replace(/<(?!\/?(?:b|i|u|strong|em|br)\b)[^>]+>/gi, '')  // strip all other tags
                    .replace(/&nbsp;/g, ' ')
                    .replace(/\s+/g, ' ')
                    .trim();
            } else {
                clean = plain;
            }
            document.execCommand('insertHTML', false, clean);
        }

        // Attach paste sanitizer to all rte-content divs once DOM is ready
        document.addEventListener('DOMContentLoaded', function() {
            document.querySelectorAll('.rte-content').forEach(el => {
                el.addEventListener('paste', rtePasteSanitize);
            });
        });

        // ── General Subjects Quiz Logic ──────────────────────────────────
        let generalQuestions = [];
        let generalQuestionNumber = 1;
        let currentPassageText = '';
        let passageQuestionNumber = 1;

        function setGeneralMode(mode) {
            const isPassage = mode === 'passage';
            document.getElementById('standaloneSection').style.display = isPassage ? 'none' : 'block';
            document.getElementById('passageSection').style.display    = isPassage ? 'block' : 'none';
            document.getElementById('modeStandaloneBtn').classList.toggle('active', !isPassage);
            document.getElementById('modePassageBtn').classList.toggle('active', isPassage);
        }

        function toggleGeneralAnswerType() {
            const type = document.querySelector('input[name="generalAnswerFormat"]:checked').value;
            document.getElementById('generalMCQOptions').style.display   = type === 'mcq'       ? 'block' : 'none';
            document.getElementById('generalTFOptions').style.display    = type === 'truefalse'  ? 'block' : 'none';
            document.getElementById('generalShortOptions').style.display = type === 'short'      ? 'block' : 'none';
        }

        function appendToQuestionList(q) {
            const label = q.passage ? `<span class="badge bg-info me-1">Passage Q</span>` : '';
            document.getElementById('generalQuestionsContainer').innerHTML +=
                `<div class="alert alert-light border mb-2 py-2">
                    ${label}<strong>Q${q.number}:</strong> ${q.text}
                    <span class="badge bg-success ms-2">${q.answer}</span>
                </div>`;
            document.getElementById('generalQCount').textContent = generalQuestions.length;
            document.getElementById('generalQuestionsList').style.display = 'block';
        }

        function generalSaveAndNext() {
            const el = document.getElementById('generalQuestionText');
            const text = el.innerHTML.replace(/&nbsp;/g, ' ').replace(/<br\s*\/?>/gi, '').trim();
            if (!text) { alert('Please enter a question.'); return; }

            const type = document.querySelector('input[name="generalAnswerFormat"]:checked').value;
            let answer = '', options = [];

            if (type === 'mcq') {
                options = ['generalOpt1','generalOpt2','generalOpt3','generalOpt4'].map(id => document.getElementById(id).value.trim());
                if (options.some(o => !o)) { alert('Please fill in all 4 options.'); return; }
                answer = document.getElementById('generalCorrectMCQ').value;
            } else if (type === 'truefalse') {
                answer = document.getElementById('generalCorrectTF').value;
            } else {
                answer = document.getElementById('generalCorrectShort').value.trim();
                if (!answer) { alert('Please enter the expected answer.'); return; }
            }

            const explanation = document.getElementById('generalExplanation').value.trim();
            const q = { number: generalQuestionNumber, text, type, options, answer, explanation };
            generalQuestions.push(q);
            appendToQuestionList(q);

            generalQuestionNumber++;
            document.getElementById('generalQuestionNumber').textContent = generalQuestionNumber;
            document.getElementById('generalQuestionText').innerHTML = '';
            document.getElementById('generalExplanation').value = '';
            ['generalOpt1','generalOpt2','generalOpt3','generalOpt4'].forEach(id => document.getElementById(id).value = '');
        }

        // ── Passage functions ─────────────────────────────────────────────
        function confirmPassage() {
            const text = document.getElementById('passageText').value.trim();
            if (!text) { alert('Please enter a passage.'); return; }
            currentPassageText = text;
            passageQuestionNumber = 1;
            document.getElementById('passagePreview').textContent = text;
            document.getElementById('passageQuestionNumber').textContent = passageQuestionNumber;
            document.getElementById('passageStep1').style.display = 'none';
            document.getElementById('passageStep2').style.display = 'block';
        }

        function editPassage() {
            document.getElementById('passageStep2').style.display = 'none';
            document.getElementById('passageStep1').style.display = 'block';
        }

        function addNewPassage() {
            currentPassageText = '';
            document.getElementById('passageText').value = '';
            document.getElementById('passageStep2').style.display = 'none';
            document.getElementById('passageStep1').style.display = 'block';
            ['pOpt1','pOpt2','pOpt3','pOpt4'].forEach(id => document.getElementById(id).value = '');
            document.getElementById('passageQuestionText').value = '';
        }

        function passageSaveAndNext() {
            const el = document.getElementById('passageQuestionText');
            const text = el.innerHTML.replace(/&nbsp;/g, ' ').replace(/<br\s*\/?>/gi, '').trim();
            if (!text) { alert('Please enter a question.'); return; }
            const options = ['pOpt1','pOpt2','pOpt3','pOpt4'].map(id => document.getElementById(id).value.trim());
            if (options.some(o => !o)) { alert('Please fill in all 4 options.'); return; }
            const answer = document.getElementById('passageCorrect').value;

            const explanation = document.getElementById('passageExplanation').value.trim();
            const q = { number: generalQuestionNumber, text, type: 'mcq', options, answer, explanation, passage: currentPassageText };
            generalQuestions.push(q);
            appendToQuestionList(q);

            passageQuestionNumber++;
            generalQuestionNumber++;
            document.getElementById('passageQuestionNumber').textContent = passageQuestionNumber;
            document.getElementById('passageQuestionText').innerHTML = '';
            document.getElementById('passageExplanation').value = '';
            ['pOpt1','pOpt2','pOpt3','pOpt4'].forEach(id => document.getElementById(id).value = '');
            document.getElementById('passageCorrect').value = 'A';
        }

        async function generalFinishQuiz() {
            const title = document.getElementById('generalTitle').value.trim();
            const gradeRaw = document.getElementById('generalGrade').value;
            const subjectRaw = document.getElementById('generalSubject').value;

            if (!title)    { alert('Please enter a quiz title.'); return; }
            if (!gradeRaw) { alert('Please select a grade level.'); return; }
            if (!subjectRaw){ alert('Please select a subject.'); return; }
            if (generalQuestions.length === 0) { alert('Please add at least one question.'); return; }

            // Map grade value to model enum
            const gradeMap = {
                '1':'1st grade','2':'2nd grade','3':'3rd grade','4':'4th grade',
                '5':'5th grade','6':'6th grade','7':'7th grade','8':'8th grade',
                '9':'9th grade','10':'10th grade','11':'11th grade','12':'12th grade',
                'sat_verbal':'SAT Verbal','sat_math':'SAT Math','sat_general':'SAT General Questionnaire','generic':'Generic Questionnaire'
            };
            const subjectMap = {
                'english':'English','science':'Science','history':'History',
                'geography':'Geography','general':'General Knowledge','other':'Other'
            };
            const gradeLevel = gradeMap[gradeRaw] || gradeRaw;
            const subject    = subjectMap[subjectRaw] || subjectRaw;

            // Transform questions to the format /create-quiz-manual expects
            const mappedQuestions = generalQuestions.map(q => {
                if (q.type === 'mcq') {
                    const answerIndex = ['A','B','C','D'].indexOf(q.answer);
                    return {
                        questionText: q.text,
                        answerFormat: 'multiple',
                        options: q.options,
                        correctAnswers: [answerIndex >= 0 ? answerIndex : 0],
                        selectionType: 'single',
                        hasImage: false,
                        explanation: q.explanation || '',
                        passage: q.passage || ''
                    };
                } else if (q.type === 'truefalse') {
                    return {
                        questionText: q.text,
                        answerFormat: 'multiple',
                        options: ['True', 'False'],
                        correctAnswers: [q.answer === 'True' ? 0 : 1],
                        selectionType: 'single',
                        hasImage: false,
                        explanation: q.explanation || '',
                        passage: q.passage || ''
                    };
                } else {
                    return {
                        questionText: q.text,
                        answerFormat: 'text',
                        expectedAnswer: q.answer,
                        hasImage: false,
                        explanation: q.explanation || '',
                        passage: q.passage || ''
                    };
                }
            });

            const description = document.getElementById('generalDescription').value.trim();

            try {
                const formData = new FormData();
                formData.append('title', title);
                formData.append('description', description || 'General subjects quiz');
                formData.append('gradeLevel', gradeLevel);
                formData.append('subjects', subject);
                formData.append('language', 'English');
                formData.append('quizType', document.querySelector('input[name="generalQuizType"]:checked').value);
                formData.append('isManuallyCreated', 'true');
                formData.append('questions', JSON.stringify(mappedQuestions));
                formData.append('questionImageIndexes', JSON.stringify([]));

                const res = await fetch('/create-quiz-manual', { method: 'POST', body: formData });
                const data = await res.json().catch(() => ({}));
                if (res.ok) {
                    alert(data.message || 'Quiz created successfully!');
                    window.location.href = '/teacher/dashboard';
                } else {
                    alert('Error: ' + (data.error || data || 'Could not save quiz.'));
                }
            } catch (err) {
                alert('Error saving quiz: ' + err.message);
            }
        }



        // ===== PDF VISION UPLOADER =====
        function pvFileSelected(input) {
            const file = input.files[0];
            if (!file) return;
            if (!file.name.toLowerCase().endsWith('.pdf')) {
                document.getElementById('pvError').textContent = 'Only PDF files are supported.';
                document.getElementById('pvError').style.display = 'block';
                input.value = '';
                return;
            }
            if (file.size > 20 * 1024 * 1024) {
                document.getElementById('pvError').textContent = 'File is too large. Maximum size is 20 MB.';
                document.getElementById('pvError').style.display = 'block';
                input.value = '';
                return;
            }
            document.getElementById('pvError').style.display = 'none';
            document.getElementById('pvFileName').textContent = file.name;
            document.getElementById('pvFileSize').textContent = '(' + (file.size / 1024).toFixed(0) + ' KB)';
            document.getElementById('pvFileInfo').style.display = 'flex';
        }

        function pvClearFile() {
            document.getElementById('pvFile').value = '';
            document.getElementById('pvFileInfo').style.display = 'none';
        }

        function pvAnswerFileSelected(input) {
            const file = input.files[0];
            if (!file) return;
            if (!file.name.toLowerCase().endsWith('.pdf')) {
                document.getElementById('pvError').textContent = 'Answer key must be a PDF file.';
                document.getElementById('pvError').style.display = 'block';
                input.value = '';
                return;
            }
            if (file.size > 10 * 1024 * 1024) {
                document.getElementById('pvError').textContent = 'Answer key is too large. Maximum size is 10 MB.';
                document.getElementById('pvError').style.display = 'block';
                input.value = '';
                return;
            }
            document.getElementById('pvError').style.display = 'none';
            document.getElementById('pvAnswerFileName').textContent = file.name;
            document.getElementById('pvAnswerFileSize').textContent = '(' + (file.size / 1024).toFixed(0) + ' KB)';
            document.getElementById('pvAnswerFileInfo').style.display = 'flex';
        }

        function pvClearAnswerFile() {
            document.getElementById('pvAnswerFile').value = '';
            document.getElementById('pvAnswerFileInfo').style.display = 'none';
        }

        // Drag-and-drop for both zones
        document.addEventListener('DOMContentLoaded', () => {
            function setupDrop(zoneId, inputId, handlerFn, bgDefault, bgOver) {
                const zone = document.getElementById(zoneId);
                if (!zone) return;
                zone.addEventListener('dragover', e => { e.preventDefault(); zone.style.background = bgOver; });
                zone.addEventListener('dragleave', () => { zone.style.background = bgDefault; });
                zone.addEventListener('drop', e => {
                    e.preventDefault();
                    zone.style.background = bgDefault;
                    const file = e.dataTransfer.files[0];
                    if (file) {
                        const dt = new DataTransfer();
                        dt.items.add(file);
                        document.getElementById(inputId).files = dt.files;
                        handlerFn(document.getElementById(inputId));
                    }
                });
            }
            setupDrop('pvDropZone', 'pvFile', pvFileSelected, '#fff5f7', '#ffe0e8');
            setupDrop('pvAnswerDropZone', 'pvAnswerFile', pvAnswerFileSelected, '#f8f9fa', '#e8f5e9');
        });

        async function pvSubmit() {
            const title   = document.getElementById('pvTitle').value.trim();
            const subject = document.getElementById('pvSubject').value;
            const grade   = document.getElementById('pvGrade').value;
            const quizType = document.querySelector('input[name="pvQuizType"]:checked').value;
            const file    = document.getElementById('pvFile').files[0];
            const errEl   = document.getElementById('pvError');

            errEl.style.display = 'none';
            if (!title)   { errEl.textContent = 'Please enter a quiz title.'; errEl.style.display = 'block'; return; }
            if (!subject) { errEl.textContent = 'Please select a subject.'; errEl.style.display = 'block'; return; }
            if (!grade)   { errEl.textContent = 'Please select a grade level.'; errEl.style.display = 'block'; return; }
            if (!file)    { errEl.textContent = 'Please select a PDF file.'; errEl.style.display = 'block'; return; }

            const answerFile = document.getElementById('pvAnswerFile').files[0];
            const fd = new FormData();
            fd.append('title', title);
            fd.append('subject', subject);
            fd.append('gradeLevel', grade);
            fd.append('quizType', quizType);
            fd.append('questionPaper', file);
            if (answerFile) fd.append('answerPaper', answerFile);

            document.getElementById('pvSubmitBtn').disabled = true;
            document.getElementById('pvProgress').style.display = 'block';

            const steps = [
                { pct: 15, msg: 'Uploading PDF...' },
                { pct: 35, msg: 'Converting pages to images...' },
                { pct: 60, msg: 'Claude AI reading questions and diagrams...' },
                { pct: 85, msg: 'Structuring questions...' },
                { pct: 95, msg: 'Saving quiz...' }
            ];
            let stepIdx = 0;
            const bar = document.getElementById('pvProgressBar');
            const msg = document.getElementById('pvProgressMsg');
            const progressInterval = setInterval(() => {
                if (stepIdx < steps.length) {
                    bar.style.width = steps[stepIdx].pct + '%';
                    msg.textContent = steps[stepIdx].msg;
                    stepIdx++;
                }
            }, 4000);

            try {
                // Step 1: upload PDFs and create background job (returns immediately)
                const uploadRes = await fetch('/create-quiz-vision', { method: 'POST', body: fd });
                clearInterval(progressInterval);
                let uploadData = null;
                const rawText = await uploadRes.text().catch(() => '');
                try { uploadData = JSON.parse(rawText); } catch(e) {}
                if (!uploadRes.ok) {
                    bar.style.width = '0%';
                    document.getElementById('pvProgress').style.display = 'none';
                    const serverMsg = (uploadData && uploadData.message) || rawText.slice(0, 200) || 'Upload failed. Please try again.';
                    errEl.textContent = `Error (${uploadRes.status}): ${serverMsg}`;
                    errEl.style.display = 'block';
                    document.getElementById('pvSubmitBtn').disabled = false;
                    return;
                }

                const jobId = uploadData && uploadData.jobId;
                if (!jobId) {
                    errEl.textContent = 'Server did not return a job ID. Please try again.';
                    errEl.style.display = 'block';
                    document.getElementById('pvSubmitBtn').disabled = false;
                    return;
                }

                // Step 2: poll job status every 5 seconds
                bar.style.width = '40%';
                msg.textContent = 'PDF uploaded. Claude AI is reading your questions...';

                const pollInterval = setInterval(async () => {
                    try {
                        const pollRes = await fetch(`/api/quiz-job/${jobId}`);
                        const pollData = await pollRes.json().catch(() => null);
                        if (!pollData) return;

                        if (pollData.status === 'processing' || pollData.status === 'pending') {
                            if (pollData.progressMessage) msg.textContent = pollData.progressMessage;
                            // Animate bar between 40-90%
                            const current = parseFloat(bar.style.width) || 40;
                            if (current < 90) bar.style.width = Math.min(current + 5, 90) + '%';
                        } else if (pollData.status === 'done') {
                            clearInterval(pollInterval);
                            bar.style.width = '100%';
                            msg.textContent = 'Done! Redirecting...';
                            setTimeout(() => { window.location.href = '/teacher/dashboard'; }, 800);
                        } else if (pollData.status === 'error') {
                            clearInterval(pollInterval);
                            document.getElementById('pvProgress').style.display = 'none';
                            errEl.textContent = pollData.errorMessage || 'Failed to extract questions. Please try again.';
                            errEl.style.display = 'block';
                            document.getElementById('pvSubmitBtn').disabled = false;
                        }
                    } catch(e) { /* network blip — keep polling */ }
                }, 5000);

            } catch (err) {
                clearInterval(progressInterval);
                document.getElementById('pvProgress').style.display = 'none';
                errEl.textContent = 'Network error. Please check your connection and try again.';
                errEl.style.display = 'block';
                document.getElementById('pvSubmitBtn').disabled = false;
            }
        }
        // ===== END PDF VISION UPLOADER =====

    </script>
