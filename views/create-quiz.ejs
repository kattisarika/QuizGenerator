        // Finish quiz creation
        async function finishQuiz() {
            // Validate quiz info
            const title = document.getElementById('manualTitle').value.trim();
            const grade = document.getElementById('manualGrade').value;
            const subject = document.getElementById('manualSubject').value;
            const description = document.getElementById('manualDescription').value.trim();
            const quizType = document.querySelector('input[name="manualQuizType"]:checked').value;

            if (!title || !grade || !subject) {
                alert('Please fill in all required quiz information');
                return;
            }

            // Check if current question should be saved
            const questionText = getQuestionText().trim();
            if (questionText) {
                if (confirm('Do you want to save the current question before finishing?')) {
                    saveAndNext();
                }
            }

            if (manualQuestions.length === 0) {
                alert('Please add at least one question to the quiz');
                return;
            }

            // Prepare quiz data
            const quizData = {
                title: title,
                description: description,
                gradeLevel: grade,
                subjects: subject,
                language: 'English',
                quizType: quizType,
                questions: manualQuestions,
                isManuallyCreated: true
            };

            // Submit quiz
            try {
                // Create FormData for file uploads
                const formData = new FormData();
                
                // Add quiz metadata
                formData.append('title', title);
                formData.append('description', description);
                formData.append('gradeLevel', grade);
                formData.append('subjects', subject);
                formData.append('language', 'English');
                formData.append('quizType', quizType);
                formData.append('isManuallyCreated', 'true');
                
                // Process questions and add images
                const processedQuestions = [];
                const imageFiles = [];
                const questionImageIndexes = [];
                
                manualQuestions.forEach((question, index) => {
                    const processedQuestion = { ...question };
                    
                    if (question.image && question.image instanceof File) {
                        // Mark question as having an image
                        processedQuestion.hasImage = true;
                        // Add image file to FormData
                        formData.append('questionImages', question.image);
                        // Store question index for this image
                        questionImageIndexes.push(index);
                        imageFiles.push(question.image);
                    } else {
                        processedQuestion.hasImage = false;
                    }
                    
                    processedQuestions.push(processedQuestion);
                });
                
                // Add all question image indexes as a single array
                formData.append('questionImageIndexes', JSON.stringify(questionImageIndexes));
                
                // Add processed questions data
                formData.append('questions', JSON.stringify(processedQuestions));
                
                console.log('Submitting quiz with:', {
                    questionsCount: processedQuestions.length,
                    imagesCount: imageFiles.length
                });
                
                const response = await fetch('/create-quiz-manual', {
                    method: 'POST',
                    body: formData
                });

                if (response.ok) {
                    const result = await response.json();
                    // Show success message with the final title that includes date/time
                    showTempMessage(result.message || 'Quiz created successfully!', 'success', 5000);
                    setTimeout(() => {
                        window.location.href = '/teacher/dashboard';
                    }, 2000);
                } else {
                    const error = await response.text();
                    alert('Error creating quiz: ' + error);
                }
            } catch (error) {
                alert('Error creating quiz: ' + error.message);
            }
        }

