        }

        async function autoFormatQuestion() {
            const textarea = document.getElementById('questionText');
            const btn = document.getElementById('autoFormatBtn');
            const text = textarea.value.trim();
            if (!text) { alert('Please type a question first.'); return; }

            btn.disabled = true;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin me-1"></i>Formatting...';

            try {
                const res = await fetch('/api/format-math-question', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ text })
                });
                const data = await res.json();
                if (data.success) {
                    textarea.value = data.formatted;
                    updateMathPreview();
                } else {
                    alert(data.message || 'Could not format question.');
                }
            } catch (e) {
                alert('Network error. Please try again.');
            } finally {
                btn.disabled = false;
                btn.innerHTML = '<i class="fas fa-magic me-1"></i>Auto-Format Math';
            }
        }

        function updateMathPreview() {
            const text = document.getElementById('questionText').value;
            const preview = document.getElementById('mathQuestionPreview');
            const content = document.getElementById('mathQuestionPreviewContent');
            if (!text.trim()) { preview.style.display = 'none'; return; }
            preview.style.display = 'block';
            content.innerHTML = text;
            if (window.MathJax) MathJax.typesetPromise([content]).catch(() => {});
        }

        // ===== DESMOS GRAPH BUILDER =====
        // ===== CANVAS GRAPHING ENGINE =====
        let graphCanvas = null, graphCtx = null;
        let graphExpressions = [];
        let graphView = { xMin: -8, xMax: 8, yMin: -5, yMax: 5 };
        const GRAPH_COLORS = ['#2563eb','#dc2626','#16a34a','#9333ea','#d97706','#0891b2'];

