    <script>
        // Quiz Type Selection
        function selectQuizType(type) {
            // Update radio button
            document.getElementById('type-' + type).checked = true;

            // Update visual state
            document.querySelectorAll('.quiz-type-content').forEach(card => {
                card.classList.remove('active');
            });
            document.getElementById(type + '-card').classList.add('active');

            // You can add additional logic here based on quiz type
            console.log('Selected quiz type:', type);
        }



        // Show complex builder info
        function showComplexBuilderInfo() {
            alert(`Complex Quiz Builder Features:

🎨 Drag & Drop Canvas: Visually design your quiz layout
📝 Rich Text Boxes: Add formatted text anywhere
🖼️ Image Placement: Upload and position images precisely
📊 Charts & Graphs: Create bar charts, line charts, and pie charts
🧮 LaTeX Support: Add mathematical formulas and equations
📋 Dynamic Tables: Create and edit tables with custom content
❓ Question Hierarchy: Organize main questions and sub-questions
✍️ Answer Areas: Designate spaces for student responses

Perfect for creating complex assessments, math problems, science diagrams, and interactive learning materials!`);
        }

        function handleFileSelect(input, type) {
            const file = input.files[0];
            const infoDiv = document.getElementById(type + 'Info');

            if (file) {
                const fileSize = (file.size / 1024 / 1024).toFixed(2);
                const fileType = file.name.split('.').pop().toUpperCase();

                infoDiv.innerHTML = `
                    <div class="d-flex align-items-center">
                        <i class="fas fa-file-${fileType === 'PDF' ? 'pdf' : 'word'} me-2 text-primary"></i>
                        <div class="flex-grow-1">
                            <strong>${file.name}</strong><br>
                            <small class="text-muted">${fileSize} MB • ${fileType}</small>
                            ${(fileType === 'PDF' || fileType === 'DOCX') ?
