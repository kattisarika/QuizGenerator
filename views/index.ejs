    <!-- Teachers Directory -->
    <% if (teachers && teachers.length > 0) { %>
    <div style="padding: 3rem 2rem;">
        <h2 style="color: #f43f5e; margin-bottom: 0.25rem;">
            <i class="fas fa-users me-2"></i>Find Your Teacher
        </h2>
        <p style="color: #9d4a5a; margin-bottom: 2rem;">Connect with your teacher and join their organization using the code below</p>

        <div class="row g-3">
            <% teachers.forEach(function(teacher) { %>
            <div class="col-lg-2 col-md-3 col-sm-4 col-6">
                <div class="card h-100 border-0" style="border-radius: 14px; background: rgba(255,255,255,0.75); box-shadow: 0 2px 12px rgba(251,113,133,0.12); transition: transform 0.2s ease, box-shadow 0.2s ease;"
                     onmouseenter="this.style.transform='translateY(-4px)';this.style.boxShadow='0 8px 24px rgba(251,113,133,0.2)'"
                     onmouseleave="this.style.transform='';this.style.boxShadow='0 2px 12px rgba(251,113,133,0.12)'">
                    <div class="card-body text-center p-3">
                        <div style="width:48px;height:48px;background:linear-gradient(135deg,#fda4af,#fb7185);border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 0.6rem;">
                            <i class="fas fa-chalkboard-teacher text-white" style="font-size:18px;"></i>
                        </div>
                        <h6 class="mb-1" style="color:#2c3e50;font-weight:700;font-size:0.85rem;"><%= teacher.displayName %></h6>

                        <% if (teacher.organizationId && teacher.organizationId.name) { %>
                        <p class="mb-2" style="color:#f43f5e;font-size:0.75rem;font-weight:600;">
                            <i class="fas fa-school me-1"></i><%= teacher.organizationId.name %>
                        </p>
                        <div class="input-group input-group-sm mb-2">
                            <input type="text" class="form-control text-center fw-bold"
                                   value="<%= teacher.organizationId.subdomain || 'N/A' %>"
                                   readonly id="orgCode_<%= teacher._id %>"
                                   style="font-family:monospace;font-size:0.75rem;background:#fff0f3;border:1.5px solid #fda4af;">
                            <button class="btn btn-sm" type="button"
                                    onclick="copyCode('<%= teacher._id %>')"
                                    style="background:#fb7185;color:white;border:none;">
                                <i class="fas fa-copy"></i>
                            </button>
                        </div>
                        <% if (teacher.organizationId.subdomain) { %>
                        <a href="/signup?code=<%= teacher.organizationId.subdomain %>"
                           class="btn btn-sm w-100"
                           style="background:linear-gradient(135deg,#fda4af,#fb7185);color:white;border:none;border-radius:20px;font-size:0.78rem;">
                            <i class="fas fa-user-plus me-1"></i>Join
                        </a>
                        <% } %>
                        <% } else { %>
                        <p class="text-muted" style="font-size:0.75rem;">Not configured</p>
                        <% } %>
                    </div>
                </div>
            </div>
            <% }); %>
        </div>
    </div>
    <% } %>

    <!-- Features Section -->
