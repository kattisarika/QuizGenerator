<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SkillOns - Quiz Platform for Teachers</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <style>
        html {
            scroll-behavior: smooth;
        }

        body {
            background: #fff0f3;
            min-height: 100vh;
            font-family: 'Inter', sans-serif;
            margin: 0;
            padding: 0;
            overflow-x: hidden;
            color: #1e293b;
        }

        /* Navigation Bar Styles */
        .navbar-custom {
            background: rgba(255, 255, 255, 0.97) !important;
            backdrop-filter: blur(10px);
            box-shadow: 0 2px 16px rgba(251, 113, 133, 0.1);
            padding: 1rem 0;
            position: fixed;
            top: 0;
            width: 100%;
            z-index: 1000;
            transition: all 0.3s ease;
            border-bottom: 1px solid rgba(253, 164, 175, 0.2);
        }

        .navbar-custom .navbar-brand {
            color: #f43f5e !important;
            font-size: 1.8rem;
            font-weight: bold;
            text-decoration: none;
        }

        .navbar-custom .navbar-brand:hover {
            color: #fb7185 !important;
            transform: scale(1.04);
        }

        .navbar-custom .navbar-nav .nav-link {
            color: #374151 !important;
            font-weight: 600;
            margin: 0 0.5rem;
            padding: 0.5rem 1rem !important;
            border-radius: 25px;
            transition: all 0.3s ease;
        }

        .navbar-custom .navbar-nav .nav-link:hover {
            color: #f43f5e !important;
            background: #fff1f2;
            transform: translateY(-2px);
        }

        .navbar-custom .btn-nav {
            margin: 0 0.25rem;
            padding: 0.5rem 1.5rem;
            border-radius: 25px;
            font-weight: 600;
            text-decoration: none;
            transition: all 0.3s ease;
        }

        .btn-nav-primary {
            background: linear-gradient(135deg, #fda4af, #fb7185);
            color: white !important;
            border: none;
            font-weight: 700;
        }

        .btn-nav-primary:hover {
            background: linear-gradient(135deg, #fb7185, #f43f5e);
            color: white !important;
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(251, 113, 133, 0.4);
        }

        .btn-nav-outline {
            background: transparent;
            color: #f43f5e !important;
            border: 2px solid #fda4af;
        }

        .btn-nav-outline:hover {
            background: #fff1f2;
            color: #e11d48 !important;
            border-color: #fb7185;
            transform: translateY(-2px);
        }

        .navbar-toggler {
            border: 2px solid #fda4af;
            padding: 0.25rem 0.5rem;
            border-radius: 8px;
        }

        .navbar-toggler:focus {
            box-shadow: 0 0 0 0.2rem rgba(251, 113, 133, 0.2);
        }

        .navbar-toggler-icon {
            background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 30 30'%3e%3cpath stroke='%23f43f5e' stroke-linecap='round' stroke-miterlimit='10' stroke-width='2' d='M4 7h22M4 15h22M4 23h22'/%3e%3c/svg%3e");
        }

        .hero-section {
            padding: 9rem 2rem 5rem 2rem;
            text-align: center;
            background: #fff0f3;
            color: #1e293b;
            position: relative;
            overflow: hidden;
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 80vh;
        }

        .hero-inner {
            max-width: 680px;
            width: 100%;
            position: relative;
            z-index: 2;
        }

        .hero-section::before {
            content: '';
            position: absolute;
            top: 50%; left: 50%;
            transform: translate(-50%, -50%);
            width: 70%;
            height: 70%;
            background: radial-gradient(ellipse, #fecdd3 0%, transparent 70%);
            pointer-events: none;
        }

        .hero-section::after { display: none; }

        .hero-title {
            font-size: 3.5rem;
            font-weight: 800;
            margin-bottom: 1rem;
            color: #f43f5e;
        }

        .hero-subtitle {
            font-size: 1.4rem;
            margin-bottom: 1rem;
            color: #4b2333;
            font-weight: 600;
        }

        .lead1 {
            color: #6b4552;
            font-size: 1.05rem;
            margin-bottom: 2.5rem;
        }

        .cta-buttons {
            margin: 2rem 0;
        }

        .cta-button {
            margin: 0.5rem;
            padding: 1rem 2rem;
            font-size: 1.1rem;
            border-radius: 50px;
            text-decoration: none;
            transition: all 0.3s ease;
        }

        .btn-primary-custom {
            background: linear-gradient(135deg, #fb7185, #f43f5e);
            color: white;
            border: none;
            position: relative;
            z-index: 2;
            font-weight: 700;
            box-shadow: 0 4px 16px rgba(244, 63, 94, 0.3);
        }

        .btn-primary-custom:hover {
            background: linear-gradient(135deg, #f43f5e, #e11d48);
            color: white;
            transform: translateY(-3px);
            box-shadow: 0 8px 24px rgba(244, 63, 94, 0.4);
        }

        .btn-outline-custom {
            background: white;
            color: #f43f5e;
            border: 2px solid #fda4af;
            position: relative;
            z-index: 2;
            font-weight: 600;
        }

        .btn-outline-custom:hover {
            background: #fff0f3;
            color: #e11d48;
            border-color: #fb7185;
            transform: translateY(-3px);
            box-shadow: 0 8px 20px rgba(244, 63, 94, 0.15);
        }

        .features-section {
            background: #fff0f3;
            padding: 3rem 2rem;
            position: relative;
        }

        .features-section::before {
            display: none;
        }

        .features-section .container {
            position: relative;
            z-index: 1;
        }

        .feature-card {
            text-align: center;
            padding: 2.5rem;
            border-radius: 20px;
            box-shadow: 0 4px 24px rgba(251, 113, 133, 0.08);
            margin-bottom: 2rem;
            height: 100%;
            background: white;
            border: 1px solid rgba(253, 164, 175, 0.35);
            transition: all 0.3s ease;
            color: #374151;
        }

        .feature-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 16px 40px rgba(251, 113, 133, 0.16);
            border-color: #fda4af;
        }

        .feature-card h4 {
            color: #1e293b;
            font-weight: 700;
            margin-bottom: 0.75rem;
        }

        .feature-icon {
            font-size: 3rem;
            background: linear-gradient(135deg, #fda4af, #fb7185);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            margin-bottom: 1.5rem;
            display: block;
        }

        .debug-info {
            background: rgba(255,255,255,0.6);
            backdrop-filter: blur(10px);
            border-radius: 15px;
            padding: 2rem;
            margin: 2rem 0;
            color: #374151;
        }

        .organization-info {
            background: #fff1f2;
            border-radius: 10px;
            padding: 1rem;
            margin: 1rem 0;
        }
    </style>
</head>
