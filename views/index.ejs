    </nav>

    <!-- Hero Section -->
    <div class="hero-section" id="home">
        <div class="hero-inner">
        <h1 class="hero-title">
                <i class="fas fa-graduation-cap me-3"></i>
                SkillOns
            </h1>
            <p class="hero-subtitle">
                The Complete SaaS Quiz Platform for Teachers
            </p>
