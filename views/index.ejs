                </a>
                <% if (user) { %>
                <a href="/dashboard" class="btn btn-outline-custom cta-button">
                    <i class="fas fa-tachometer-alt me-2"></i>
                    Go to Dashboard
                </a>
                <% } else { %>
                <a href="/login" class="btn btn-outline-custom cta-button">
