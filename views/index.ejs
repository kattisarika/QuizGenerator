        <div class="row">
            <div class="col-12 mb-5">
                <h2 style="color: #f43f5e; font-weight: bold; margin-bottom: 0.5rem;">Why Choose SkillOns?</h2>
                <p class="lead" style="color: #6b7280; font-size: 1.1rem;">Complete isolation, unlimited possibilities</p>
