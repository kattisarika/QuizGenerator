<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Advanced Quiz Builder — SkillOns</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <script>
    window.MathJax = {
      tex: { inlineMath: [['$','$'],['\\(','\\)']], displayMath: [['$$','$$'],['\\[','\\]']] },
      svg: { fontCache: 'global' }
    };
  </script>
  <script id="MathJax-script" async src="https://cdn.jsdelivr.net/npm/mathjax@3/es5/tex-mml-chtml.js"></script>
  <style>
    body { background: #fdf5f5; font-family: 'Inter', sans-serif; color: #1e293b; }
    .navbar { background: rgba(255,255,255,0.97); box-shadow: 0 2px 12px rgba(140,21,21,0.08); }
    .navbar-brand { color: #8C1515 !important; font-weight: 700; }

    .page-header {
      background: linear-gradient(135deg, #c8a8a8, #8C1515);
      color: white; padding: 1.5rem 2rem; border-radius: 14px; margin-bottom: 2rem;
    }

    /* Settings panel */
    .settings-card {
      background: white; border-radius: 12px; border: 2px solid #e9ecef;
      padding: 1.5rem; margin-bottom: 1.5rem;
    }

    /* Question cards */
    .question-card {
      background: white; border-radius: 12px; border: 2px solid #e9ecef;
      padding: 1.25rem 1.5rem; margin-bottom: 1rem; position: relative;
    }
    .question-card:hover { border-color: #c8a8a8; }

    .q-number {
      width: 36px; height: 36px; border-radius: 50%;
      background: linear-gradient(135deg, #c8a8a8, #8C1515);
      color: white; font-weight: 700; font-size: 0.9rem;
      display: flex; align-items: center; justify-content: center; flex-shrink: 0;
    }

    .form-control:focus, .form-select:focus {
      border-color: #8C1515; box-shadow: 0 0 0 0.2rem rgba(140,21,21,0.15);
    }

    .question-type-badge {
      font-size: 0.72rem; padding: 3px 10px; border-radius: 20px;
      background: rgba(140,21,21,0.1); color: #8C1515; font-weight: 600;
    }

    .option-row { display: flex; align-items: center; gap: 8px; margin-bottom: 6px; }
    .option-letter {
      width: 28px; height: 28px; border-radius: 50%; background: #f1f5f9;
      color: #64748b; font-weight: 700; font-size: 0.8rem;
      display: flex; align-items: center; justify-content: center; flex-shrink: 0;
    }
    .option-letter.correct { background: #dcfce7; color: #16a34a; }

    .math-hint {
      background: #fffbeb; border: 1px solid #fde68a; border-radius: 8px;
      padding: 10px 14px; font-size: 0.82rem; color: #92400e; margin-top: 8px;
    }
    .math-hint code { background: #fef3c7; padding: 1px 5px; border-radius: 4px; }

    /* Preview panel */
    .preview-card {
      background: white; border-radius: 12px; border: 2px solid #e9ecef;
      padding: 1.5rem; margin-bottom: 1rem;
    }
    .preview-question {
      background: #f8fafc; border-radius: 8px; padding: 14px;
      margin-bottom: 10px; border-left: 4px solid #8C1515;
    }

    /* Bottom save bar */
    .save-bar {
      position: sticky; bottom: 0;
      background: white; border-top: 2px solid #e9ecef;
      padding: 1rem 0; margin-top: 2rem;
      box-shadow: 0 -4px 20px rgba(0,0,0,0.08);
    }
    .btn-save {
      background: linear-gradient(135deg, #c8a8a8, #8C1515); color: white;
      border: none; border-radius: 25px; padding: 10px 32px; font-weight: 600;
    }
    .btn-save:hover { background: linear-gradient(135deg, #8C1515, #6b0f0f); color: white; }
    .btn-add {
      background: white; color: #8C1515; border: 2px solid #c8a8a8;
      border-radius: 25px; padding: 8px 22px; font-weight: 600;
    }
    .btn-add:hover { background: #fdf5f5; color: #8C1515; border-color: #8C1515; }
    .btn-del {
      width: 30px; height: 30px; border-radius: 50%; background: #fee2e2;
      color: #ef4444; border: none; font-size: 0.8rem;
      display: flex; align-items: center; justify-content: center;
    }
    .btn-del:hover { background: #ef4444; color: white; }

    /* Tabs */
    .nav-tabs .nav-link { color: #6b7280; border: none; border-bottom: 2px solid transparent; }
    .nav-tabs .nav-link.active { color: #8C1515; border-bottom-color: #8C1515; font-weight: 600; background: none; }
    .nav-tabs { border-bottom: 2px solid #e9ecef; }
  </style>
</head>
<body>
  <nav class="navbar navbar-expand-lg mb-4">
    <div class="container-xl">
      <a class="navbar-brand" href="/teacher/dashboard"><i class="fas fa-graduation-cap me-2"></i>SkillOns</a>
      <a href="/teacher/dashboard" class="btn btn-sm ms-auto" style="color:#8C1515;border:2px solid #c8a8a8;border-radius:20px;">
        <i class="fas fa-arrow-left me-1"></i> Dashboard
      </a>
    </div>
  </nav>

  <div class="container-xl" style="max-width:1000px;">

    <div class="page-header">
      <h4 class="mb-1"><i class="fas fa-magic me-2"></i>Advanced Quiz Builder</h4>
      <div style="opacity:0.9;font-size:0.95rem;">Create math and science quizzes with equations, multiple choice, or open-ended answers</div>
    </div>

    <div id="alertBox"></div>

    <!-- Quiz Settings -->
    <div class="settings-card">
      <h6 class="fw-700 mb-3" style="color:#8C1515;"><i class="fas fa-cog me-2"></i>Quiz Settings</h6>
      <div class="row g-3">
        <div class="col-md-6">
          <label class="form-label fw-600">Quiz Title <span class="text-danger">*</span></label>
          <input type="text" id="quizTitle" class="form-control" placeholder="e.g. Algebra 1 – Solving Systems of Equations">
        </div>
        <div class="col-md-3">
          <label class="form-label fw-600">Grade Level <span class="text-danger">*</span></label>
          <select id="quizGrade" class="form-select">
            <option value="">Select Grade</option>
            <option value="1st grade">1st Grade</option>
            <option value="2nd grade">2nd Grade</option>
            <option value="3rd grade">3rd Grade</option>
            <option value="4th grade">4th Grade</option>
            <option value="5th grade">5th Grade</option>
            <option value="6th grade">6th Grade</option>
            <option value="7th grade">7th Grade</option>
            <option value="8th grade">8th Grade</option>
            <option value="9th grade">9th Grade</option>
            <option value="10th grade">10th Grade</option>
            <option value="11th grade">11th Grade</option>
            <option value="12th grade">12th Grade</option>
            <option value="Young Adult Education">Young Adult Education</option>
          </select>
        </div>
        <div class="col-md-3">
          <label class="form-label fw-600">Subject <span class="text-danger">*</span></label>
          <select id="quizSubject" class="form-select">
            <option value="">Select Subject</option>
            <option value="Math">Math</option>
            <option value="Science">Science</option>
            <option value="English">English</option>
            <option value="Python">Python</option>
            <option value="Tableau">Tableau</option>
            <option value="Power BI">Power BI</option>
          </select>
        </div>
        <div class="col-md-6">
          <label class="form-label fw-600">Description</label>
          <input type="text" id="quizDescription" class="form-control" placeholder="Optional description">
        </div>
        <div class="col-md-3">
          <label class="form-label fw-600">Quiz Type</label>
          <select id="quizType" class="form-select">
            <option value="regular">Regular Quiz</option>
            <option value="competitive">Competitive Quiz</option>
          </select>
        </div>
        <div class="col-md-3">
          <label class="form-label fw-600">Points per Question</label>
          <input type="number" id="defaultPoints" class="form-control" value="1" min="1" max="100">
        </div>
      </div>
    </div>

    <!-- Tabs: Build / Preview -->
    <ul class="nav nav-tabs mb-3" id="builderTabs">
      <li class="nav-item">
        <button class="nav-link active" onclick="showTab('build')"><i class="fas fa-edit me-1"></i>Build</button>
      </li>
      <li class="nav-item">
        <button class="nav-link" onclick="showTab('preview')"><i class="fas fa-eye me-1"></i>Preview</button>
      </li>
    </ul>

    <!-- Build Tab -->
    <div id="tab-build">
      <div id="questionsContainer"></div>

      <div class="d-flex gap-2 mt-3 mb-4">
        <button class="btn btn-add" onclick="addQuestion('open')">
          <i class="fas fa-plus me-1"></i>Add Open-Ended Question
        </button>
        <button class="btn btn-add" onclick="addQuestion('mcq')">
          <i class="fas fa-list-ul me-1"></i>Add Multiple Choice
        </button>
      </div>

      <div class="math-hint">
        <strong><i class="fas fa-info-circle me-1"></i>Math Equations:</strong>
        Use <code>$...$</code> for inline math (e.g. <code>$-6x + 5y = 19$</code>) and
        <code>$$...$$</code> for display math (e.g. <code>$$\frac{-b \pm \sqrt{b^2-4ac}}{2a}$$</code>).
        Equations will render automatically in the Preview tab and for students.
      </div>
    </div>

    <!-- Preview Tab -->
    <div id="tab-preview" style="display:none;">
      <div id="previewContainer"></div>
    </div>

    <!-- Save Bar -->
    <div class="save-bar">
      <div class="container-xl" style="max-width:1000px;">
        <div class="d-flex justify-content-between align-items-center">
          <div style="color:#6b7280;font-size:0.9rem;">
            <i class="fas fa-question-circle me-1"></i>
            <span id="questionCount">0</span> question(s)
          </div>
          <button class="btn btn-save" onclick="saveQuiz()">
            <i class="fas fa-save me-2"></i>Save Quiz
          </button>
        </div>
      </div>
    </div>

  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    let questions = [];
    let questionIdCounter = 0;

    // ── Tab switching ──────────────────────────────────────────────────────────
    function showTab(tab) {
      document.getElementById('tab-build').style.display = tab === 'build' ? '' : 'none';
      document.getElementById('tab-preview').style.display = tab === 'preview' ? '' : 'none';
      document.querySelectorAll('#builderTabs .nav-link').forEach((btn, i) => {
        btn.classList.toggle('active', (i === 0 && tab === 'build') || (i === 1 && tab === 'preview'));
      });
      if (tab === 'preview') renderPreview();
    }

    // ── Add a new question ─────────────────────────────────────────────────────
    function addQuestion(type) {
      const id = ++questionIdCounter;
      const q = { id, type, text: '', options: ['', '', '', ''], correctIndex: 0, points: parseInt(document.getElementById('defaultPoints').value) || 1 };
      questions.push(q);
      renderQuestion(q);
      updateCount();
      // Scroll to new question
      setTimeout(() => {
        const el = document.getElementById('q-card-' + id);
        if (el) el.scrollIntoView({ behavior: 'smooth', block: 'center' });
      }, 50);
    }

    // ── Render a single question card ──────────────────────────────────────────
    function renderQuestion(q) {
      const container = document.getElementById('questionsContainer');
      const div = document.createElement('div');
      div.className = 'question-card';
      div.id = 'q-card-' + q.id;
      div.innerHTML = buildQuestionHTML(q);
      container.appendChild(div);
    }

    function buildQuestionHTML(q) {
      const num = questions.indexOf(q) + 1;
      const typeLabel = q.type === 'mcq' ? 'Multiple Choice' : 'Open-Ended';
      const letters = ['A','B','C','D','E'];

      let optionsHTML = '';
      if (q.type === 'mcq') {
        optionsHTML = `<div class="mt-3">
          <label class="form-label fw-600" style="font-size:0.85rem;color:#6b7280;">Answer Options <small>(check the correct one)</small></label>`;
        for (let j = 0; j < 4; j++) {
          const isCorrect = q.correctIndex === j;
          optionsHTML += `
          <div class="option-row">
            <div class="option-letter ${isCorrect ? 'correct' : ''}" id="opt-letter-${q.id}-${j}">${letters[j]}</div>
            <input type="text" class="form-control form-control-sm" id="opt-${q.id}-${j}"
                   placeholder="Option ${letters[j]}" value="${escHtml(q.options[j] || '')}"
                   oninput="updateOption(${q.id},${j},this.value)">
            <input type="radio" name="correct-${q.id}" ${isCorrect ? 'checked' : ''}
                   onchange="setCorrect(${q.id},${j})" title="Mark as correct answer"
                   style="width:18px;height:18px;accent-color:#16a34a;cursor:pointer;">
            <span style="font-size:0.75rem;color:#6b7280;white-space:nowrap;">Correct</span>
          </div>`;
        }
        optionsHTML += `</div>`;
      } else {
        optionsHTML = `
        <div class="mt-2">
          <label class="form-label fw-600" style="font-size:0.85rem;color:#6b7280;">Correct Answer <small>(for grading reference)</small></label>
          <input type="text" class="form-control form-control-sm" id="ans-${q.id}"
                 placeholder="e.g. x=3, y=2  (students will write their full solution)"
                 value="${escHtml(q.options[0] || '')}"
                 oninput="updateCorrectAnswer(${q.id},this.value)">
        </div>`;
      }

      return `
      <div class="d-flex gap-3 align-items-start mb-3">
        <div class="q-number">${num}</div>
        <div class="flex-grow-1">
          <div class="d-flex justify-content-between align-items-center mb-2">
            <span class="question-type-badge">${typeLabel}</span>
            <div class="d-flex align-items-center gap-2">
              <label style="font-size:0.8rem;color:#6b7280;">Pts:</label>
              <input type="number" class="form-control form-control-sm" style="width:65px;" min="1" max="100"
                     value="${q.points}" oninput="updatePoints(${q.id},this.value)">
              <button class="btn-del" onclick="deleteQuestion(${q.id})" title="Delete question">
                <i class="fas fa-times"></i>
              </button>
            </div>
          </div>
          <textarea class="form-control" rows="2" id="qtext-${q.id}"
                    placeholder="Enter question text. Use $...$ for math equations, e.g: Solve: $-6x + 5y = 19$ and $-4x - 5y = -29$"
                    oninput="updateText(${q.id},this.value)">${escHtml(q.text)}</textarea>
          ${optionsHTML}
        </div>
      </div>`;
    }

    // ── Rebuild all question cards (after delete/reorder) ──────────────────────
    function rebuildAll() {
      const container = document.getElementById('questionsContainer');
      container.innerHTML = '';
      questions.forEach(q => renderQuestion(q));
      updateCount();
    }

    // ── Update helpers ─────────────────────────────────────────────────────────
    function updateText(id, val) {
      const q = questions.find(q => q.id === id);
      if (q) q.text = val;
    }

    function updateOption(id, idx, val) {
      const q = questions.find(q => q.id === id);
      if (q) q.options[idx] = val;
    }

    function updateCorrectAnswer(id, val) {
      const q = questions.find(q => q.id === id);
      if (q) q.options[0] = val;
    }

    function updatePoints(id, val) {
      const q = questions.find(q => q.id === id);
      if (q) q.points = parseInt(val) || 1;
    }

    function setCorrect(id, idx) {
      const q = questions.find(q => q.id === id);
      if (!q) return;
      q.correctIndex = idx;
      // Update letter badge colors
      for (let j = 0; j < 4; j++) {
        const letter = document.getElementById('opt-letter-' + id + '-' + j);
        if (letter) letter.className = 'option-letter' + (j === idx ? ' correct' : '');
      }
    }

    function deleteQuestion(id) {
      questions = questions.filter(q => q.id !== id);
      rebuildAll();
    }

    function updateCount() {
      document.getElementById('questionCount').textContent = questions.length;
    }

    // ── Sync current textarea values into questions array ──────────────────────
    function syncFromDOM() {
      questions.forEach(q => {
        const textEl = document.getElementById('qtext-' + q.id);
        if (textEl) q.text = textEl.value;

        if (q.type === 'mcq') {
          for (let j = 0; j < 4; j++) {
            const optEl = document.getElementById('opt-' + q.id + '-' + j);
            if (optEl) q.options[j] = optEl.value;
          }
        } else {
          const ansEl = document.getElementById('ans-' + q.id);
          if (ansEl) q.options[0] = ansEl.value;
        }
      });
    }

    // ── Preview renderer ───────────────────────────────────────────────────────
    function renderPreview() {
      syncFromDOM();
      const container = document.getElementById('previewContainer');
      if (questions.length === 0) {
        container.innerHTML = '<div class="text-center text-muted py-5"><i class="fas fa-edit fa-3x mb-3"></i><p>No questions added yet. Go to the Build tab to add questions.</p></div>';
        return;
      }

      const letters = ['A','B','C','D'];
      let html = '';
      questions.forEach((q, i) => {
        const optionsHtml = q.type === 'mcq'
          ? q.options.filter(o => o.trim()).map((o, j) =>
              `<div style="padding:6px 0;display:flex;gap:10px;align-items:flex-start;">
                <span style="font-weight:700;color:#8C1515;min-width:20px;">${letters[j]}.</span>
                <span>${o}</span>
              </div>`).join('')
          : `<div style="margin-top:8px;border:1px dashed #cbd5e1;border-radius:6px;padding:10px;color:#94a3b8;font-size:0.85rem;">
               Student writes answer here
             </div>`;

        html += `<div class="preview-question">
          <div style="display:flex;gap:12px;align-items:flex-start;">
            <span style="font-weight:700;color:#8C1515;font-size:1rem;min-width:28px;">${i+1}.</span>
            <div style="flex:1;">
              <div class="math-render">${q.text || '<em style="color:#94a3b8;">No question text</em>'}</div>
              <div style="margin-top:10px;">${optionsHtml}</div>
            </div>
            <span style="font-size:0.78rem;color:#94a3b8;">${q.points} pt${q.points !== 1 ? 's' : ''}</span>
          </div>
        </div>`;
      });

      container.innerHTML = html;

      // Typeset math
      if (window.MathJax && MathJax.typesetPromise) {
        MathJax.typesetPromise([container]).catch(e => console.log('MathJax error:', e));
      }
    }

    // ── Save quiz ──────────────────────────────────────────────────────────────
    function saveQuiz() {
      syncFromDOM();

      const title = document.getElementById('quizTitle').value.trim();
      const grade = document.getElementById('quizGrade').value;
      const subject = document.getElementById('quizSubject').value;
      const quizType = document.getElementById('quizType').value;
      const description = document.getElementById('quizDescription').value.trim();

      if (!title) return showAlert('danger', 'Please enter a quiz title.');
      if (!grade) return showAlert('danger', 'Please select a grade level.');
      if (!subject) return showAlert('danger', 'Please select a subject.');
      if (questions.length === 0) return showAlert('danger', 'Please add at least one question.');

      const emptyQ = questions.find(q => !q.text.trim());
      if (emptyQ) {
        const num = questions.indexOf(emptyQ) + 1;
        return showAlert('danger', `Question ${num} has no text. Please fill it in.`);
      }

      // Build elements array for server (compatible with existing complex quiz format)
      const elements = [];
      questions.forEach((q, i) => {
        // Question element
        elements.push({
          id: 'q-' + (i + 1),
          type: 'question',
          pageNumber: i + 1,
          questionNumber: i + 1,
          content: q.text,
          questionType: q.type,
          points: q.points,
          x: 0, y: 0, width: 800, height: 120
        });

        if (q.type === 'mcq') {
          // Store MCQ options and correct answer as answer-area element
          elements.push({
            id: 'a-' + (i + 1),
            type: 'answer-area',
            pageNumber: i + 1,
            questionNumber: i + 1,
            mcqOptions: q.options.filter(o => o.trim()),
            correctIndex: q.correctIndex,
            correctAnswer: q.options[q.correctIndex] || '',
            x: 0, y: 130, width: 800, height: 150
          });
        } else {
          elements.push({
            id: 'a-' + (i + 1),
            type: 'answer-area',
            pageNumber: i + 1,
            questionNumber: i + 1,
            correctAnswer: q.options[0] || '',
            x: 0, y: 130, width: 800, height: 120
          });
        }
      });

      const quizData = {
        title, description, gradeLevel: grade, subject, quizType,
        elements,
        isComplexQuiz: true
      };

      const btn = document.querySelector('.btn-save');
      btn.disabled = true;
      btn.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i>Saving...';

      fetch('/create-complex-quiz', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(quizData)
      })
      .then(r => r.json())
      .then(data => {
        if (data.success) {
          showAlert('success', 'Quiz saved successfully! Redirecting...');
          setTimeout(() => window.location.href = '/teacher/dashboard', 1500);
        } else {
          throw new Error(data.message || 'Failed to save quiz');
        }
      })
      .catch(err => {
        showAlert('danger', 'Error: ' + err.message);
        btn.disabled = false;
        btn.innerHTML = '<i class="fas fa-save me-2"></i>Save Quiz';
      });
    }

    function showAlert(type, msg) {
      const box = document.getElementById('alertBox');
      box.innerHTML = `<div class="alert alert-${type} d-flex align-items-center gap-2 mb-3">
        <i class="fas fa-${type === 'success' ? 'check-circle' : 'exclamation-circle'}"></i>${msg}
      </div>`;
      box.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      if (type === 'success') setTimeout(() => box.innerHTML = '', 4000);
    }

    function escHtml(s) {
      return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    }

    // Start with one empty open-ended question
    addQuestion('open');
  </script>
</body>
</html>
