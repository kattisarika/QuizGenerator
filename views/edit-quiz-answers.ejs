<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Edit Answer Key — <%= quiz.title %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
    body { background: #fdf5f5; font-family: 'Inter', sans-serif; color: #1e293b; }
    .navbar { background: rgba(255,255,255,0.97); box-shadow: 0 2px 12px rgba(140,21,21,0.08); }
    .navbar-brand { color: #8C1515 !important; font-weight: 700; }
    .page-header { background: linear-gradient(135deg, #c8a8a8, #8C1515); color: white; padding: 1.5rem 2rem; border-radius: 14px; margin-bottom: 2rem; }
    .question-card {
      background: white;
      border-radius: 12px;
      border: 2px solid #e9ecef;
      padding: 1.25rem 1.5rem;
      margin-bottom: 1rem;
      transition: border-color 0.2s;
    }
    .question-card.answered { border-color: #c8a8a8; }
    .question-card.unanswered { border-color: #fbbf24; background: #fffbeb; }
    .q-number {
      width: 32px; height: 32px; border-radius: 50%;
      background: linear-gradient(135deg, #c8a8a8, #8C1515);
      color: white; font-weight: 700; font-size: 0.85rem;
      display: flex; align-items: center; justify-content: center;
      flex-shrink: 0;
    }
    .q-number.unanswered { background: linear-gradient(135deg, #fbbf24, #f59e0b); }
    .question-text { font-weight: 500; flex: 1; }
    .option-label {
      display: flex; align-items: center; gap: 10px;
      padding: 8px 12px; border-radius: 8px; cursor: pointer;
      border: 2px solid #e9ecef; margin-bottom: 6px;
      transition: all 0.15s;
    }
    .option-label:hover { border-color: #c8a8a8; background: rgba(140,21,21,0.04); }
    .option-label input[type="radio"] { accent-color: #8C1515; width: 18px; height: 18px; }
    .option-label.selected { border-color: #8C1515; background: rgba(140,21,21,0.06); font-weight: 600; }
    .option-badge {
      width: 26px; height: 26px; border-radius: 50%;
      background: #f1f5f9; color: #64748b;
      font-weight: 700; font-size: 0.78rem;
      display: flex; align-items: center; justify-content: center;
      flex-shrink: 0;
    }
    .save-bar {
      position: sticky; bottom: 0;
      background: white; border-top: 2px solid #e9ecef;
      padding: 1rem 0; margin-top: 2rem;
      box-shadow: 0 -4px 20px rgba(0,0,0,0.08);
    }
    .btn-save { background: linear-gradient(135deg, #c8a8a8, #8C1515); color: white; border: none; border-radius: 25px; padding: 10px 32px; font-weight: 600; }
    .btn-save:hover { background: linear-gradient(135deg, #8C1515, #6b0f0f); color: white; }
    .progress-bar-custom { background: linear-gradient(135deg, #c8a8a8, #8C1515); }
    .status-badge { font-size: 0.75rem; padding: 3px 10px; border-radius: 20px; }
    .badge-filled { background: rgba(140,21,21,0.1); color: #8C1515; }
    .badge-empty { background: #fef3c7; color: #92400e; }
    .short-answer-input { border: 2px solid #e9ecef; border-radius: 8px; padding: 8px 12px; width: 100%; font-size: 0.9rem; }
    .short-answer-input:focus { outline: none; border-color: #8C1515; }
  </style>
</head>
<body>
  <nav class="navbar navbar-expand-lg mb-4">
    <div class="container">
      <a class="navbar-brand" href="/teacher/dashboard"><i class="fas fa-graduation-cap me-2"></i>SkillOns</a>
      <a href="/teacher/dashboard" class="btn btn-sm" style="color:#8C1515;border:2px solid #c8a8a8;border-radius:20px;">
        <i class="fas fa-arrow-left me-1"></i> Back to Dashboard
      </a>
    </div>
  </nav>

  <div class="container" style="max-width:860px;">

    <div class="page-header">
      <div class="d-flex justify-content-between align-items-start">
        <div>
          <h4 class="mb-1"><i class="fas fa-key me-2"></i>Answer Key Editor</h4>
          <div style="opacity:0.9;font-size:0.95rem;"><%= quiz.title %></div>
        </div>
        <div class="text-end">
          <div style="font-size:1.5rem;font-weight:700;" id="filledCount">0</div>
          <div style="font-size:0.8rem;opacity:0.85;">of <%= quiz.questions.length %> answered</div>
        </div>
      </div>
      <div class="progress mt-3" style="height:6px;background:rgba(255,255,255,0.3);border-radius:3px;">
        <div class="progress-bar progress-bar-custom" id="progressBar" style="width:0%;border-radius:3px;"></div>
      </div>
    </div>

    <div id="alertBox"></div>

    <form id="answerForm">
      <% quiz.questions.forEach(function(q, i) { %>
        <%
          const hasAnswer = q.correctAnswer && q.correctAnswer.trim() !== '';
          const isShortAnswer = !q.options || q.options.length === 0;
        %>
        <div class="question-card <%= hasAnswer ? 'answered' : 'unanswered' %>" id="card-<%= i %>">
          <div class="d-flex gap-3 align-items-start mb-3">
            <div class="q-number <%= hasAnswer ? '' : 'unanswered' %>" id="qnum-<%= i %>"><%= i + 1 %></div>
            <div class="question-text"><%- q.question %></div>
            <span class="status-badge <%= hasAnswer ? 'badge-filled' : 'badge-empty' %>" id="badge-<%= i %>">
              <%= hasAnswer ? 'Set' : 'Not set' %>
            </span>
          </div>

          <% if (isShortAnswer) { %>
            <div class="ms-5">
              <label style="font-size:0.85rem;color:#6b7280;margin-bottom:4px;">Correct answer:</label>
              <input type="text" class="short-answer-input answer-input"
                     data-index="<%= i %>"
                     value="<%= q.correctAnswer || '' %>"
                     placeholder="Type the correct answer...">
            </div>
          <% } else { %>
            <div class="ms-5">
              <% q.options.forEach(function(opt, j) { %>
                <% const letters = ['A','B','C','D','E']; %>
                <%
                  const isSelected = q.correctAnswer && (
                    q.correctAnswer.trim() === opt.trim() ||
                    q.correctAnswer.trim().toUpperCase() === letters[j]
                  );
                %>
                <label class="option-label <%= isSelected ? 'selected' : '' %>" id="lbl-<%= i %>-<%= j %>">
                  <input type="radio"
                         name="answer-<%= i %>"
                         class="answer-radio"
                         data-index="<%= i %>"
                         value="<%= opt %>"
                         <%= isSelected ? 'checked' : '' %>>
                  <div class="option-badge"><%= letters[j] %></div>
                  <span><%= opt %></span>
                </label>
              <% }); %>
            </div>
          <% } %>
        </div>
      <% }); %>

      <div class="save-bar">
        <div class="container" style="max-width:860px;">
          <div class="d-flex justify-content-between align-items-center">
            <div style="color:#6b7280;font-size:0.9rem;">
              <i class="fas fa-info-circle me-1"></i>
              <span id="unsetCount">0</span> question(s) without an answer key will always be marked wrong.
            </div>
            <button type="submit" class="btn btn-save" id="saveBtn">
              <i class="fas fa-save me-2"></i>Save Answer Key
            </button>
          </div>
        </div>
      </div>
    </form>

  </div>

  <script>
    const totalQuestions = <%= quiz.questions.length %>;

    function updateProgress() {
      let filled = 0;

      // Count radio selections
      document.querySelectorAll('.answer-radio').forEach(r => {
        if (r.checked) {
          const idx = r.dataset.index;
          // Update card state
          document.getElementById('card-' + idx).className = 'question-card answered';
          document.getElementById('qnum-' + idx).className = 'q-number';
          document.getElementById('badge-' + idx).className = 'status-badge badge-filled';
          document.getElementById('badge-' + idx).textContent = 'Set';
        }
      });

      // Count filled short answers
      document.querySelectorAll('.answer-input').forEach(inp => {
        const idx = inp.dataset.index;
        const hasVal = inp.value.trim() !== '';
        document.getElementById('card-' + idx).className = 'question-card ' + (hasVal ? 'answered' : 'unanswered');
        document.getElementById('qnum-' + idx).className = 'q-number' + (hasVal ? '' : ' unanswered');
        document.getElementById('badge-' + idx).className = 'status-badge ' + (hasVal ? 'badge-filled' : 'badge-empty');
        document.getElementById('badge-' + idx).textContent = hasVal ? 'Set' : 'Not set';
      });

      // Recount all answered
      document.querySelectorAll('.question-card.answered').forEach(() => filled++);
      filled = document.querySelectorAll('.question-card.answered').length;

      document.getElementById('filledCount').textContent = filled;
      document.getElementById('progressBar').style.width = Math.round(filled / totalQuestions * 100) + '%';
      document.getElementById('unsetCount').textContent = totalQuestions - filled;
    }

    // Highlight selected option labels
    document.querySelectorAll('.answer-radio').forEach(radio => {
      radio.addEventListener('change', function() {
        const name = this.name;
        document.querySelectorAll(`input[name="${name}"]`).forEach(r => {
          r.closest('.option-label').classList.remove('selected');
        });
        this.closest('.option-label').classList.add('selected');
        updateProgress();
      });
    });

    document.querySelectorAll('.answer-input').forEach(inp => {
      inp.addEventListener('input', updateProgress);
    });

    // Save
    document.getElementById('answerForm').addEventListener('submit', async function(e) {
      e.preventDefault();
      const btn = document.getElementById('saveBtn');
      btn.disabled = true;
      btn.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i>Saving...';

      const answers = {};

      document.querySelectorAll('.answer-radio:checked').forEach(r => {
        answers[r.dataset.index] = r.value;
      });
      document.querySelectorAll('.answer-input').forEach(inp => {
        answers[inp.dataset.index] = inp.value.trim();
      });

      try {
        const res = await fetch('/teacher/quiz/<%= quiz._id %>/answers', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ answers })
        });
        const data = await res.json();
        if (data.success) {
          document.getElementById('alertBox').innerHTML = `
            <div class="alert alert-success d-flex align-items-center gap-2 mb-3">
              <i class="fas fa-check-circle"></i> Answer key saved successfully!
            </div>`;
        } else {
          throw new Error(data.message);
        }
      } catch (err) {
        document.getElementById('alertBox').innerHTML = `
          <div class="alert alert-danger mb-3"><i class="fas fa-exclamation-circle me-2"></i>${err.message}</div>`;
      }

      btn.disabled = false;
      btn.innerHTML = '<i class="fas fa-save me-2"></i>Save Answer Key';
      setTimeout(() => document.getElementById('alertBox').innerHTML = '', 4000);
    });

    updateProgress();
  </script>
</body>
</html>
